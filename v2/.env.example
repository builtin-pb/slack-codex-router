# v2 loads the repo-root `.env` by default; set `DOTENV_CONFIG_PATH` to override.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USER_ID=
# Compatibility alias accepted by the v2 loader during cutover.
ALLOWED_SLACK_USER_ID=
# Current repo-root aliases supported by default.
SCR_PROJECTS_FILE=config/projects.yaml
SCR_STATE_DB=logs/router-v2/state.sqlite3
# Shorter overrides are also accepted if present.
PROJECTS_FILE=config/projects.yaml
ROUTER_STATE_DB=logs/router-v2/state.sqlite3
CODEX_APP_SERVER_COMMAND=codex app-server
